# Environment configuration example
# Copy this file to .env and update the values

# Database connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Node environment (development, test, production)
NODE_ENV=development

# Application port
PORT=3000

# CI configuration
# Set CI=true in your CI environment to use mock database instead of real connections
# CI=true

# For CI environments, you can use a fake DATABASE_URL
# The system will automatically use mocks when CI=true
# DATABASE_URL=postgresql://fake:fake@localhost:5432/fake_db?schema=public

# Other configuration variables can be added here
