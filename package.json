{
  "name": "calendar-management",
  "version": "1.0.0",
  "description": "API pour la gestion d'agenda immobilier",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean-tests": "rm -rf dist/tests",
    "build:clean": "npm run build && npm run clean-tests",
    "prod": "cross-env NODE_ENV=production node dist/index.js",
    "start": "node dist/index.js",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "npx cross-env NODE_ENV=test SKIP_DB_CONNECTION=true jest --config jest.config.js",
    "seed": "ts-node prisma/seed.ts",
    "lint": "eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json,md}'",
    "generate": "npx prisma generate"
  },
  "keywords": [
    "agenda",
    "immobilier",
    "api",
    "typescript"
  ],
  "author": "Dynastie AMOUSSOU",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@types/jsonwebtoken": "^9.0.9",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@jest/reporters": "^29.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.17.30",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.4",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "supertest": "^6.3.4",
    "testcafe": "^3.5.0",
    "testcontainers": "^10.25.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/locaccm/calendarManagement.git"
  },
  "bugs": {
    "url": "https://github.com/locaccm/calendarManagement/issues"
  },
  "homepage": "https://github.com/locaccm/calendarManagement#readme"
}